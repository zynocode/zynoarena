{
  "name": "openboard-arcade",
  "private": true,
  "version": "1.1.0",
  "description": "A premium open-source collection of multiplayer browser board games and retro minigames built with React 19, Phaser 4, and TypeScript. Featuring Ludo Royale and Stockfish-powered Chess.",
  "keywords": [
    "react-chess",
    "multiplayer-board-games",
    "stockfish-js",
    "open-source-games",
    "phaser-4",
    "react-19",
    "offline-first",
    "browser-games",
    "chess-engine",
    "ludo-game"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "chess.js": "^1.4.0",
    "lucide-react": "^1.21.0",
    "phaser": "^4.2.0",
    "react": "^19.2.7",
    "react-chessboard": "^5.10.0",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
